{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "fresh-food-copilot",
  "main": ".open-next/worker.js",
  "workers_dev": false,
  "routes": [
    {
      "pattern": "demo.xyvialoom.com",
      "custom_domain": true,
      "zone_name": "xyvialoom.com"
    }
  ],
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "vars": {
    "DEMO_GENERATION_MODEL": "gpt-4o-mini",
    "ENABLE_TURNSTILE": "false",
    "NEXT_PUBLIC_ENABLE_TURNSTILE": "false",
    "ENABLE_RESEARCH_MODE": "true",
    "NEXT_PUBLIC_ENABLE_RESEARCH_MODE": "true",
    "OPENAI_RESEARCH_MODEL": "gpt-5.4-mini",
    "OPENAI_RESEARCH_REASONING_EFFORT": "low",
    "OPENAI_RESEARCH_SEARCH_CONTEXT_SIZE": "medium"
  },
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "observability": {
    "enabled": true
  }
}
